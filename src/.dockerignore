# ─────────────────────────────────────────────────────────────────────
# .dockerignore
#
# Files listed here are EXCLUDED from the Docker build context.
# This means Docker never sends them to the daemon — faster builds,
# smaller context, and no risk of local source files interfering
# with what the Dockerfile explicitly copies.
#
# In CI: the only thing needed in the build context is target/*.jar
#        Everything else (src/, Terraform/, kubernetes/, etc.) is noise.
# ─────────────────────────────────────────────────────────────────────
 
# Source code — NOT needed in CI Docker build (JAR already built by Maven)
src/
 
# Maven build directories other than the JAR itself
target/surefire-reports/
target/classes/
target/generated-sources/
target/maven-archiver/
target/maven-status/
target/*.original
 
# Git internals
.git/
.gitignore
 
# Project documentation and infra files (not needed inside the image)
README.md
Terraform/
kubernetes/
ansible/
docs/
*.md
 
# IDE and OS files
.idea/
.vscode/
*.iml
.DS_Store
Thumbs.db
 
# CI/CD config (not needed inside the container)
.github/
Jenkinsfile
